{
  "version": 1,
  "identifier": "default",
  "description": "Capability for all Tauri core plugins",
  "local": true,
  "windows": ["main"],
  "webviews": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-open",
    "fs:default",
    "notification:default",
    "process:default"
  ]
}
