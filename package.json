{
  "name": "video-knowledge",
  "version": "0.0.1",
  "description": "Video Knowledge - Extract knowledge from videos with AI",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/desktop",
    "apps/backend",
    "packages/shared"
  ],
  "scripts": {
    "dev:desktop": "cd apps/desktop && bun run dev",
    "dev:backend": "cd apps/backend && bun run dev",
    "build:desktop": "cd apps/desktop && bun run build",
    "build:backend": "cd apps/backend && bun run build",
    "db:push": "cd apps/backend && bun run db:push",
    "db:generate": "cd apps/backend && bun run db:generate"
  },
  "dependencies": {},
  "devDependencies": {}
}
