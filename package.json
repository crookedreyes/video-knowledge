{
  "name": "vide-know",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/desktop",
    "apps/backend",
    "packages/shared"
  ],
  "scripts": {
    "dev": "bun run dev:workspace",
